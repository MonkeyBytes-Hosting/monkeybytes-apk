<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <ScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="88dp">

        <LinearLayout
            android:id="@+id/home_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/hero_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/app_name"
                        android:elevation="8dp"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0"
                            android:text="MonkeyBytes"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Hosting control center"
                            android:textColor="#B7C0D6"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Panel"
                            android:textColor="#8F9AB3"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Ready"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Network"
                            android:textColor="#8F9AB3"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Live"
                            android:textColor="#D9FFE5"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.08"
                android:text="QUICK ACCESS"
                android:textColor="#8F9AB3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_dashboard"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#3FA3FF">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_dashboard">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Dashboard" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Manage servers and resources" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextAppearance.MonkeyBytes.ActionArrow"
                        android:text="&#8250;" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_discord"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#7F88FF">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_discord">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_discord" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Discord" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Chat with the community" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextAppearance.MonkeyBytes.ActionArrow"
                        android:text="&#8250;" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_status"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#5BD78A">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_status">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_status" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Status" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="View live network uptime" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextAppearance.MonkeyBytes.ActionArrow"
                        android:text="&#8250;" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_reminder"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#FFB454">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_reminder">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_reminder" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Reminders" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Schedule a notification" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextAppearance.MonkeyBytes.ActionArrow"
                        android:text="&#8250;" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_biometric"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#48D6C8">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_security">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            android:id="@+id/biometric_title"
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Biometric Lock" />

                        <TextView
                            android:id="@+id/biometric_subtitle"
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Set up fingerprint or face" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextAppearance.MonkeyBytes.ActionArrow"
                        android:text="&#8250;" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout"
        style="@style/Widget.MonkeyBytes.LogoutButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="18dp"
        android:text="Logout"
        app:rippleColor="#FF6B6B" />
</FrameLayout>
