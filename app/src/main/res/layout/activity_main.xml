<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/home_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="56dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/hero_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/app_name"
                        android:elevation="8dp"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0"
                            android:text="MonkeyBytes"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Hosting control center"
                            android:textColor="#B7C0D6"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_refresh_status"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="Refresh status"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        app:backgroundTint="#1A2230"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="20dp"
                        app:iconTint="#D3DAEA"
                        app:rippleColor="#3FA3FF"
                        app:strokeColor="#334058"
                        app:strokeWidth="1dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="70dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_metric_chip"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Panel"
                                android:textColor="#8F9AB3"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/panel_status_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Ready"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="70dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_metric_chip"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Network"
                                android:textColor="#8F9AB3"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/network_status_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Live"
                                android:textColor="#D9FFE5"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nodes"
                            android:textColor="#8F9AB3"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/nodes_status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Check"
                            android:textColor="#D9FFE5"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/status_last_checked_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Last checked -"
                        android:textColor="#8F9AB3"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/node_status_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="92dp"
                        android:text="Hide nodes"
                        android:textColor="#D3DAEA"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/node_status_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_metric_chip"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.08"
                android:text="QUICK ACCESS"
                android:textColor="#8F9AB3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_dashboard"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#3FA3FF">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_dashboard">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Dashboard" />

                        <TextView
                            android:id="@+id/dashboard_subtitle"
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Loading servers..." />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_status"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#5BD78A">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_status">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_status" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Status Page" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="External network uptime page" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_biometric"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#48D6C8">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_security">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            android:id="@+id/biometric_title"
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="App Lock" />

                        <TextView
                            android:id="@+id/biometric_subtitle"
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Biometric, PIN or pattern" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_reminder"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#FFB454">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_reminder">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_reminder" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Reminders" />

                        <TextView
                            android:id="@+id/reminder_subtitle"
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="No reminders scheduled" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_discord"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#7F88FF">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_discord">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_discord" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Discord" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="External community invite" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_game"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#FF6B9D">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_security">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_game" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="MonkeyRunner" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Play the infinite runner game" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.08"
                android:text="ACCOUNT"
                android:textColor="#8F9AB3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_logout"
                style="@style/Widget.MonkeyBytes.ActionCard"
                app:rippleColor="#FF6B6B">

                <LinearLayout style="@style/Widget.MonkeyBytes.ActionRow">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_security">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_logout" />
                    </FrameLayout>

                    <LinearLayout style="@style/Widget.MonkeyBytes.ActionText">

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionTitle"
                            android:text="Logout" />

                        <TextView
                            style="@style/TextAppearance.MonkeyBytes.ActionSubtitle"
                            android:text="Sign out of this device" />
                    </LinearLayout>

                    <ImageView
                        style="@style/Widget.MonkeyBytes.ActionChevron"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
